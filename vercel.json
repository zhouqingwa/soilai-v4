{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "soilai.app"
        }
      ],
      "destination": "https://www.soilai.app/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/.*|assets/.*|journal(?:/.*)?|.*\\.(?:js|css|png|jpg|jpeg|webp|avif|svg|ico|xml|txt|json|webmanifest)).*)",
      "destination": "/index.html"
    }
  ]
}
