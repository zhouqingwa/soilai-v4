# Gemini API. If you use an API relay, set GEMINI_BASE_URL to the relay endpoint
# and CUSTOM_GEMINI_API_KEY to the relay key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
CUSTOM_GEMINI_API_KEY=""
GEMINI_BASE_URL=""

# Production site URL. Used for canonical URLs, robots.txt, sitemap.xml, and OG tags.
APP_URL="https://www.soilai.app"

# Firebase client/server configuration.
FIREBASE_WEB_API_KEY=""
FIREBASE_PROJECT_ID="gen-lang-client-0617300238"
FIRESTORE_DATABASE_ID="ai-studio-e1e85e80-c2dd-4518-ac91-9e0beee46aaf"

# Required in production for secure scan limits, point deduction, and payment crediting.
# Prefer FIREBASE_SERVICE_ACCOUNT_BASE64 or FIREBASE_SERVICE_ACCOUNT_JSON in Vercel.
FIREBASE_SERVICE_ACCOUNT_BASE64=""
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# GUEST_LIMIT_SALT: Optional. Used to hash guest IPs before storing daily scan limits.
# Set this to any long random string in production.
GUEST_LIMIT_SALT="MY_RANDOM_GUEST_LIMIT_SALT"

# PayPal server credentials. Use sandbox until the account can receive live payments.
PAYPAL_ENV="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# Public frontend variables.
VITE_PAYPAL_CLIENT_ID=""
VITE_AMAZON_AFFILIATE_TAG=""
